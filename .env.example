# ARBITRA — Variables de entorno
# Copia como .env y completa los valores
# NUNCA subas .env a GitHub

# ── The Odds API ──────────────────────────────
ODDS_API_KEY=tu_key_aqui

# ── API-Football (RapidAPI) ───────────────────
FOOTBALL_API_KEY=tu_key_aqui

# ── Telegram ──────────────────────────────────
# Soporta múltiples chat IDs separados por coma
TELEGRAM_BOT_TOKEN=tu_token_aqui
TELEGRAM_CHAT_ID=chat_id_1,chat_id_2

# ── Supabase ──────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGc...
SUPABASE_ANON_KEY=eyJhbGc...

# ── Scanner Config ────────────────────────────
BANKROLL=300
SPORTS_PER_SCAN=2
# Deportes a escanear (separados por coma, usa keys de The Odds API)
# SCAN_SPORTS=soccer_epl,soccer_spain_la_liga,basketball_nba

# ── Seguridad (opcional) ─────────────────────
CRON_SECRET=tu_secret_aqui
